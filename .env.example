# ============================================================
# petadata — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your real values.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local to git. It is already in .gitignore.
# ============================================================


# ------------------------------------------------------------
# Anakin Wire API  (required — used for Amazon + YouTube data)
# ------------------------------------------------------------
# Get your API key at: https://anakin.io/account#developer
# The base URL default is correct — don't change it.
WIRE_API_KEY=your_anakin_api_key_here
WIRE_BASE_URL=https://api.anakin.io/v1

# ------------------------------------------------------------
# Wire Action IDs  (required — 5 action IDs from your Wire dashboard)
# ------------------------------------------------------------
# How to find them:
#   1. Go to https://anakin.io/wire
#   2. Search for "Amazon" → open the Amazon catalog
#   3. Click each action below → copy its action_id
#   4. Repeat for YouTube actions
#
# Amazon actions needed:
WIRE_ACTION_AMAZON_SEARCH=action_id_for_amazon_product_search
WIRE_ACTION_AMAZON_DETAILS=action_id_for_amazon_product_details
WIRE_ACTION_AMAZON_REVIEWS=action_id_for_amazon_product_reviews

# YouTube actions needed:
WIRE_ACTION_YT_SEARCH=action_id_for_youtube_search
WIRE_ACTION_YT_COMMENTS=action_id_for_youtube_comments


# ------------------------------------------------------------
# LLM Provider — choose ONE (or both, and pick at runtime)
# ------------------------------------------------------------

# --- Option A: Anthropic Claude ---
# Get your key from: https://console.anthropic.com/keys
# Required if you select "Claude" as the LLM provider in the UI.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Option B: Google Gemini ---
# Get your key from: https://aistudio.google.com/app/apikey
# Required if you select "Gemini" as the LLM provider in the UI.
GEMINI_API_KEY=your_gemini_api_key_here
